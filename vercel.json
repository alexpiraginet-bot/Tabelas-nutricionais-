{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/daily-report", "schedule": "0 2 * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "eventos.bentogelateria.com" }],
      "destination": "https://bentogelateria.com/bytes/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/", "has": [{ "type": "query", "key": "tabelas" }], "destination": "/share/tabelas.html" },
    { "source": "/", "has": [{ "type": "query", "key": "tabela" }], "destination": "/share/tabelas.html" },
    { "source": "/", "has": [{ "type": "query", "key": "cardapio" }], "destination": "/share/cardapio.html" },
    { "source": "/", "has": [{ "type": "query", "key": "delivery" }], "destination": "/share/delivery.html" },
    { "source": "/", "has": [{ "type": "query", "key": "eventos" }], "destination": "/share/eventos.html" },
    { "source": "/", "has": [{ "type": "query", "key": "parceria" }], "destination": "/share/parceria.html" },
    { "source": "/", "has": [{ "type": "query", "key": "franquia" }], "destination": "/share/parceria.html" },
    { "source": "/", "has": [{ "type": "query", "key": "vagas" }], "destination": "/share/vagas.html" },
    { "source": "/", "has": [{ "type": "query", "key": "portfolio" }], "destination": "/share/portfolio.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/bytes/(.*)\\.ics",
      "headers": [
        { "key": "Content-Type", "value": "text/calendar; charset=utf-8" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ]
}
