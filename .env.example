# Integração com o Bentô OS (controle-industria) — opcional, mas necessária
# para que os eventos fechados no site apareçam no calendário interno da equipe.
#
# IMPORTANTE: use o MESMO projeto Supabase do Bentô OS (mesmos valores abaixo).
# É isso que faz os dois sistemas compartilharem a agenda (tabela `bento_kv`,
# chave `bento:agenda`). Sem estas variáveis, o site funciona normalmente, mas
# o botão "Salvar na Agenda do Bentô OS" fica desligado.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
